# URL publique du site (utilisée pour le sitemap et le SEO)
# Exemple: https://www.lencre.ci
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# URL de votre API Laravel en production
# Exemple: https://api.lencre.ci/api/v1
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000/api/v1

# Note: Pour un déploiement sur Vercel ou Netlify, 
# configurez ces variables directement dans l'interface de l'hébergeur.
